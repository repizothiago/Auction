# Auto detect text files and perform LF normalization
* text=auto

# PowerShell scripts should have CRLF line endings on Windows
*.ps1 text eol=crlf

# Shell scripts should have LF line endings
*.sh text eol=lf

# Source code
*.cs text diff=csharp
*.csproj text
*.sln text eol=crlf
*.slnx text

# Documentation
*.md text
*.txt text

# Docker
Dockerfile text
docker-compose.yml text eol=lf

# Configuration files
*.json text
*.xml text
*.yml text eol=lf
*.yaml text eol=lf

# Ignore specific files from exports
.gitattributes export-ignore
.gitignore export-ignore
